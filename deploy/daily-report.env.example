# /etc/myapp/daily-report.env
# Environment variables for daily report scheduler.
# This file should be readable only by root (chmod 600).
#
# DAILY_REPORT_CRON_SECRET: must match the DAILY_REPORT_CRON_SECRET env var
#   configured on the Supabase Edge Function.
#   Generate with: openssl rand -hex 32
#
# DAILY_REPORT_ENDPOINT: the edge function URL.

DAILY_REPORT_CRON_SECRET="REPLACE_WITH_GENERATED_SECRET"
DAILY_REPORT_ENDPOINT="https://zjmozuivykubdqnizhob.supabase.co/functions/v1/send-daily-meetings"
