{
  "name": "meeting-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/typescript/bin/tsc && node node_modules/vite/bin/vite.js build",
    "lint": "node node_modules/eslint/bin/eslint.js . --max-warnings 0",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "clean-test-data": "node scripts/clean-test-data.js",
    "set-admin": "node scripts/set-admin.js",
    "test": "npm run test:recurrence && npm run test:meeting-record && npm run test:calendar-url && npm run test:meeting-prefill && npm run test:layout-navigation",
    "test:recurrence": "node --import tsx --test tests/meetings/buildRecurringMeetingRecords.test.ts",
    "test:meeting-record": "node --import tsx --test tests/meetings/buildMeetingPersistenceRecord.test.ts",
    "test:calendar-url": "node --import tsx --test tests/meetings/buildGoogleCalendarEventUrl.test.ts",
    "test:meeting-prefill": "node --import tsx --test tests/meetings/buildMeetingEditPrefill.test.ts",
    "test:layout-navigation": "node --import tsx --test tests/app/layoutNavigation.test.ts"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "@supabase/supabase-js": "2.110.2",
    "@types/react-datepicker": "^6.2.0",
    "exceljs": "^4.4.0",
    "html-to-image": "^1.11.11",
    "lucide-react": "1.24.0",
    "moment": "^2.30.1",
    "moment-jalaali": "^0.10.0",
    "node-fetch": "^3.3.2",
    "peerjs": "^1.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.4.1",
    "simple-peer": "^9.11.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/moment-jalaali": "^0.7.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/simple-peer": "^9.11.8",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "^10.4.17",
    "dotenv": "^17.4.2",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "^17.7.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4"
  }
}
